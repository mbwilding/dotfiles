# See https://wiki.hyprland.org/Configuring/Workspace-Rules/
{{- if eq .chezmoi.hostname "anon" }}
workspace = name:main,   monitor:DP-3, default:true, layoutopt:orientation:left
workspace = name:social, monitor:DP-2, default:true, layoutopt:orientation:top
workspace = name:spare,  monitor:DP-1, default:true, layoutopt:orientation:top

windowrule {
  name = teams
  match:workspace = social
  match:class = teams-for-linux
}

windowrule {
  name = spotify
  match:workspace = social
  match:class = Spotify
}

windowrule {
  name = discord
  match:workspace = social
  match:class = discord
}

windowrule {
  name = ghostty
  match:workspace = main
  match:class = com.mitchellh.ghostty
}

# Set mouse to center monitor
exec-once = hyprctl dispatch workspace main
{{- end }}
{{- if eq .chezmoi.hostname "nona" }}
workspace = 1, monitor:eDP-1, default:true, layoutopt:orientation:left
workspace = 2, monitor:eDP-1, layoutopt:orientation:left
workspace = 3, monitor:eDP-1, layoutopt:orientation:left
workspace = 4, monitor:eDP-1, layoutopt:orientation:left
workspace = 5, monitor:eDP-1, layoutopt:orientation:left
workspace = 6, monitor:eDP-1, layoutopt:orientation:left
workspace = 7, monitor:eDP-1, layoutopt:orientation:left
workspace = 8, monitor:eDP-1, layoutopt:orientation:left
workspace = 9, monitor:eDP-1, layoutopt:orientation:left
{{- end }}

# Suppress
windowrule {
  name = suppress-event-maximize
  match:class = .*
  suppress_event = maximize
}

windowrule {
  name = idle-inhibit-fullscreen
  match:class = .*
  idle_inhibit = fullscreen
}

# Unreal Engine
windowrule {
  name = unreal-unset
  match:class = ^(UnrealEditor)$
  match:title = ^\w*$
  workspace = unset
}

windowrule {
  name = unreal-no-initial-focus
  match:class = ^(UnrealEditor)$
  match:title = ^\w*$
  no_initial_focus = true
}

windowrule {
  name = unreal-no-anim
  match:class = ^(UnrealEditor)$
  match:title = ^\w*$
  no_anim = true
}
