# System
exec-once = nm-applet
exec-once = hyprpaper
exec-once = hyprpanel
# Screen sharing
exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
{{- if eq .chezmoi.hostname "anon" }}
# Applications
exec-once = teams-for-linux
exec-once = discord
exec-once = spotify
{{- end }}
{{- if eq .chezmoi.hostname "nona" }}
# Fixes
exec-once = brightnessctl set --device=platform::micmute 0
{{- end }}
