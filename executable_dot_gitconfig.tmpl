[user]
name = Matthew Wilding
email = {{ onepasswordRead "op://Personal/Email/username" }}
signingkey = ssh-rsa 

[gpg]
format = ssh

[gpg "ssh"]
allowedSignersFile = /home/anon/.config/git/allowed_signers
{{ if eq .chezmoi.os "darwin" -}}
program = "/applications/1password.app/contents/macos/op-ssh-sign"
{{ else if eq .chezmoi.os "linux" -}}
program = "/opt/1Password/op-ssh-sign"
{{- end }}

[commit]
gpgsign = true

[sendemail]
smtpserver = smtp.gmail.com
smtpuser = {{ onepasswordRead "op://Personal/Email/username" }}
smtppass = {{ onepasswordRead "op://Personal/Email/password" }}
smtpencryption = tls
smtpserverport = 587
confirm = auto

[alias]
c = clone --recursive --depth 1
r = reset --hard
wta = worktree add
wtl = worktree list
wtr = worktree remove

[init]
defaultBranch = main

[core]
editor = nvim
autocrlf = false
{{ if (and (ne .chezmoi.os "linux") (ne .chezmoi.os "darwin")) }}
sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- end }}

[push]
autoSetupRemote = true

[merge]
tool = diffview

[mergetool]
prompt = false
keepBackup = false

[mergetool "diffview"]
cmd = nvim -n -c "DiffviewOpen" "$MERGE"

[filter "lfs"]
process = git-lfs filter-process
required = true
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f

# Providers
[includeIf "hasconfig:remote.*.url:git@gitlab.com:rwwa/**"]
path = ~/.gitconfig_rwwa

[includeIf "hasconfig:remote.*.url:git@ssh.dev.azure.com:v*/RWWA/**"]
path = ~/.gitconfig_rwwa

[includeIf "hasconfig:remote.*.url:git@rwwa.github.com:*/**"]
path = ~/.gitconfig_rwwa_github
